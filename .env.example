# ============================================================
# FCI Competitive Intelligence Agent — Environment Variables
# Copy to .env and fill in real values before deploying
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=graphite_admin
POSTGRES_PASSWORD=CHANGE_ME_pg_password
POSTGRES_DB=graphite_intel
POSTGRES_PORT=5432

# --- n8n ---
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password
N8N_ENCRYPTION_KEY=CHANGE_ME_random_32_char_string
# n8n uses the same postgres instance
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=graphite_intel
N8N_DB_POSTGRESDB_USER=n8n_user
N8N_DB_POSTGRESDB_PASSWORD=CHANGE_ME_n8n_db_password
N8N_DB_POSTGRESDB_SCHEMA=n8n

# --- OpenAI ---
OPENAI_API_KEY=sk-CHANGE_ME

# --- SendGrid ---
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=intel@yourdomain.com
SENDGRID_TO_EMAIL=team@yourdomain.com

# --- Metabase ---
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=graphite_admin
MB_DB_PASS=CHANGE_ME_pg_password
MB_DB_HOST=postgres

# --- n8n MCP (for Claude Code) ---
N8N_API_URL=http://YOUR_VPS_IP:5678
N8N_API_KEY=CHANGE_ME_n8n_api_key
